# Instagram Credentials
IG_USERNAME=your_username
IG_PASSWORD=your_password
IG_2FA_SEED=your_2fa_seed_here (Optional for automated login)
IG_SESSIONID=your_browser_session_id (Use this if your IP is blacklisted)

# ⚠️ CRITICAL: Proxy is REQUIRED when running from GitHub Actions!
# Instagram blocks data center IPs. Get a residential proxy from:
# - Bright Data (brightdata.com)
# - Smartproxy (smartproxy.com)
# - Oxylabs (oxylabs.io)
# Format: http://user:pass@host:port
IG_PROXY=your_proxy_url_here

# Anti-Bot Configuration (Optional - enabled by default)
ENABLE_ANTIBOT=true
REQUEST_DELAY_MIN=3
REQUEST_DELAY_MAX=8
WATERFALL_ENABLED=true

# AI & API Keys
GEMINI_API_KEY=your_gemini_key
PIXABAY_API_KEY=your_pixabay_key

# Content Settings
CONTENT_NICHE=Fascinating Space Facts
